# Copy this file to .env and set your values. Never commit .env.

# Ollama (local LLM) - no API key. Ensure Ollama is running: ollama serve
# Pull models: ollama pull llama3.2  &&  ollama pull nomic-embed-text
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
USE_RAG=true

# Database (optional). Default: SQLite in project root.
# After setting DATABASE_URL, run migrations from project root: alembic upgrade head
# DATABASE_URL=sqlite:///./matches.db

# MySQL (e.g. MAMP: default port 8889). Create DB first, then set REAL credentials:
# DATABASE_URL=mysql+pymysql://YOUR_MYSQL_USER:YOUR_MYSQL_PASSWORD@127.0.0.1:8889/resume_lens
# Example (MAMP default user/pass):
# DATABASE_URL=mysql+pymysql://root:root@127.0.0.1:8889/resume_lens
